{
  "name": "renamix",
  "version": "0.1.2",
  "description": "Rename folder files to random unique names. TUI or CLI, with rollback.",
  "type": "module",
  "author": "Nicholas Mendez (https://www.ngmb.dev/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngmbdev/renamix.git"
  },
  "homepage": "https://github.com/ngmbdev/renamix#readme",
  "bugs": {
    "url": "https://github.com/ngmbdev/renamix/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "renamix": "./dist/cli.js"
  },
  "files": [
    "dist"
